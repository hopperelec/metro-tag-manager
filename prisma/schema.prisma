generator client {
  provider        = "prisma-client"
  previewFeatures = ["relationJoins"]
  output          = "./generated"
}

datasource db {
  provider = "sqlite"
}

model Media {
  id Int @id @default(autoincrement())

  path     String // Should be unique among media which exists
  size     BigInt
  hash     Bytes
  exists   Boolean @default(true)
  duration Int? // in seconds, 0 means image, null means unknown
  width    Int? // in pixels, null means unknown
  height   Int? // in pixels, null means unknown

  contextTags ContextTag[]
  trainTags   TrainTag[]

  @@unique([size, hash])
}

model ContextTag {
  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  tag String

  @@id([mediaId, tag])
}

model TrainTag {
  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  trainId Int
  tag     String

  @@id([mediaId, trainId, tag])
}
