{
	"name": "metro-tag-manager",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"stylelint": "stylelint '**/*.{css,html,svelte}'",
		"format:biome": "biome check --write --unsafe .",
		"format:prisma-prettier": "prettier -w prisma/schema.prisma",
		"format": "pnpm run format:biome && pnpm run format:prisma-prettier",
		"format-check:biome": "biome check .",
		"format-check:prisma-prettier": "prettier -c prisma/schema.prisma",
		"format-check": "pnpm run format-check:biome && pnpm run format-check:prisma-prettier",
		"prisma:push": "prisma db push",
		"prisma:migratedev": "prisma migrate dev",
		"prisma:generate": "prisma generate"
	},
	"dependencies": {
		"@prisma/adapter-better-sqlite3": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"cli-progress": "^3.12.0",
		"mime": "^4.1.0",
		"pretty-bytes": "^7.1.0",
		"xxhash-wasm": "^1.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@sveltejs/kit": "^2.63.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/cli-progress": "^3.11.6",
		"@types/node": "^25.9.2",
		"autoprefixer": "^10.5.0",
		"postcss-preset-env": "^11.3.0",
		"prettier": "^3.5.3",
		"prettier-plugin-prisma": "^5.0.0",
		"prisma": "^7.8.0",
		"stylelint": "^16.15.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-standard": "^37.0.0",
		"stylelint-use-nesting": "^6.0.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tslib": "^2.8.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"browserslist": [
		"defaults",
		"iOS 12"
	]
}
